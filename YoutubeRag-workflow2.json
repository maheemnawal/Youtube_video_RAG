        "jsCode": "const input = $input.first().json;\n\nconsole.log('Webhook input:', input);\n\n// The data comes in the body property\nconst bodyData = input.body || input;\nconst question = (\n  bodyData.question || \n  bodyData['Your Question'] || \n  ''\n).trim();\n\nconsole.log('Extracted question:', question);\n\nif (!question || question.length < 5) {\n  throw new Error('Question is too short. Please provide more details.');\n}\n\nreturn [{ json: { question, timestamp: new Date().toISOString() } }];"
      },
