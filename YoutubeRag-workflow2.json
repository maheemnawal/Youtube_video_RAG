    {
      "parameters": {
        "jsCode": "const input = $input.first().json;\n\n// Extract the answer from AI Agent response\nconst answer = input.output || input.response || input.text || \"No answer available\";\n\n// Clean the answer\nconst cleanAnswer = answer\n  .replace(/\\n/g, ' ')\n  .replace(/\\r/g, '')\n  .replace(/\\t/g, ' ')\n  .trim();\n\n// Return properly formatted response\nreturn [{\n  json: {\n    success: true,\n    answer: cleanAnswer,\n    timestamp: new Date().toISOString()\n  }\n}];"
      },
