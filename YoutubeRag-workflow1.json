    {
      "parameters": {
        "jsCode": "// Get the summary from the AI response\nconst aiResponse = $input.first().json;\nconst videoData = $('Fetch Transcript from Supadata').first().json;\n\n// Handle both Ollama (response) and Gemini (output) formats\nlet summaryText = aiResponse.output || aiResponse.response || aiResponse.text || '';\n\n// Clean the summary\nconst summary = summaryText.trim();\n\n// Validate summary\nif (!summary || summary.length < 50) {\n  throw new Error('Summary generation failed or too short');\n}\n\n// Truncate if too long for Google Sheets (50,000 char limit)\nconst truncatedSummary = summary.length > 10000 \n  ? summary.substring(0, 10000) + '...[truncated]'\n  : summary;\n\nreturn [{\n  json: {\n    ...videoData,\n    summary: truncatedSummary\n  }\n}];"
      },
