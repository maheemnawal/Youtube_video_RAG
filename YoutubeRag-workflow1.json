    {
      "parameters": {
        "jsCode": "const transcriptData = $input.first().json;\nconst videoMetadata = $('Parse YouTube Metadata').first().json;\n\n// Extract transcript\nconst transcript = transcriptData.content || transcriptData.text || '';\n\n// Validation checks\nconst errors = [];\n\nif (!transcript || transcript.length < 100) {\n  errors.push('Transcript too short or missing');\n}\n\nif (transcript.includes('Transcript not available')) {\n  errors.push('Video has no transcript available');\n}\n\nif (transcript.length > 500000) {\n  errors.push('Transcript too long (>500k chars) - video might be too long');\n}\n\n// If errors, throw to stop workflow\nif (errors.length > 0) {\n  throw new Error(`Transcript validation failed: ${errors.join(', ')}`);\n}\n\n// Calculate basic stats\nconst wordCount = transcript.split(/\\s+/).length;\nconst estimatedMinutes = Math.round(wordCount / 150); // ~150 words per minute\n\nreturn [{\n  json: {\n    ...transcriptData,\n    transcript_stats: {\n      char_count: transcript.length,\n      word_count: wordCount,\n      estimated_duration_minutes: estimatedMinutes\n    }\n  }\n}];"
      },
