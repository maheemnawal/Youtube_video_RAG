      "parameters": {
        "jsCode": "const youtubeData = $input.first().json;\nconst videoData = $('extract video url').first().json; // ← FIXED THIS LINE\n\n// Check if video data exists\nif (!youtubeData.snippet || !youtubeData.contentDetails) {\n  throw new Error('Video not found, may be private or deleted');\n}\n\n// Parse ISO 8601 duration (PT15M30S → 18:40)\nfunction parseDuration(isoDuration) {\n  const match = isoDuration.match(/PT(\\d+H)?(\\d+M)?(\\d+S)?/);\n  \n  if (!match) return '0:00';\n  \n  const hours = parseInt((match[1] || '0H').replace('H', '')) || 0;\n  const minutes = parseInt((match[2] || '0M').replace('M', '')) || 0;\n  const seconds = parseInt((match[3] || '0S').replace('S', '')) || 0;\n  \n  if (hours > 0) {\n    return `${hours}:${minutes.toString().padStart(2, '0')}:${seconds.toString().padStart(2, '0')}`;\n  }\n  return `${minutes}:${seconds.toString().padStart(2, '0')}`;\n}\n\n// Get best available thumbnail (priority: maxres > high > medium > default)\nfunction getBestThumbnail(thumbnails) {\n  if (thumbnails.maxres) return thumbnails.maxres.url;\n  if (thumbnails.high) return thumbnails.high.url;\n  if (thumbnails.medium) return thumbnails.medium.url;\n  if (thumbnails.default) return thumbnails.default.url;\n  return '';\n}\n\n// Auto-detect category if not provided by user\nlet category = videoData.user_category || 'General';\nif (!videoData.user_category || videoData.user_category === '') {\n  // Use YouTube's category as fallback\n  const categoryId = youtubeData.snippet.categoryId;\n  const categoryMap = {\n    '1': 'Film & Animation',\n    '2': 'Autos & Vehicles',\n    '10': 'Music',\n    '15': 'Pets & Animals',\n    '17': 'Sports',\n    '19': 'Travel & Events',\n    '20': 'Gaming',\n    '22': 'People & Blogs',\n    '23': 'Comedy',\n    '24': 'Entertainment',\n    '25': 'News & Politics',\n    '26': 'Howto & Style',\n    '27': 'Education',\n    '28': 'Science & Technology',\n    '29': 'Nonprofits & Activism'\n  };\n  category = categoryMap[categoryId] || 'General';\n}\n\nreturn [{\n  json: {\n    // Fields from Extract Video URL (CRITICAL!)\n    video_url: videoData.video_url,\n    video_id: videoData.video_id,\n    row_id: videoData.row_id,\n    processing_start_time: videoData.processing_start_time,\n    \n    // Fields from YouTube API\n    video_title: youtubeData.snippet.title,\n    author: youtubeData.snippet.channelTitle,\n    category: category,\n    duration: parseDuration(youtubeData.contentDetails.duration),\n    thumbnail_url: getBestThumbnail(youtubeData.snippet.thumbnails),\n    published_at: youtubeData.snippet.publishedAt,\n    view_count: youtubeData.statistics?.viewCount || '0',\n    like_count: youtubeData.statistics?.likeCount || '0',\n    comment_count: youtubeData.statistics?.commentCount || '0'\n  }\n}];"
      },
