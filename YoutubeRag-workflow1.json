    {
      "parameters": {
        "content": "Extract URL from sheet\nGet the metadata from youtube\nParse Metadata\nUpdate sheets with metadata\nThen get the transcript from supadata",
        "height": 288,
        "width": 1728
      },
      "type": "n8n-nodes-base.stickyNote",
      "position": [
        368,
        -160
      ],
      "typeVersion": 1,
      "id": "bbf63375-cbbb-4f96-929f-45dbf150c424",
      "name": "Sticky Note3"
    },
    {
      "parameters": {
        "jsCode": "const transcriptData = $input.first().json;\nconst videoMetadata = $('Parse YouTube Metadata').first().json;\nconst urlData = $('extract video url').first().json;\n\n// Extract transcript text - CRITICAL: Make sure this has actual content\nconst transcript = transcriptData.content || transcriptData.text || transcriptData.transcript || '';\n\nconsole.log('Transcript length:', transcript.length);\nconsole.log('Transcript preview:', transcript.substring(0, 200));\n\nif (!transcript || transcript.length < 100) {\n  throw new Error(`Transcript too short or missing. Got ${transcript.length} chars`);\n}\n\n// Chunking function with overlap\nfunction chunkTextWithOverlap(text, chunkSize = 1000, overlap = 200) {\n  const chunks = [];\n  let start = 0;\n  \n  while (start < text.length) {\n    const end = Math.min(start + chunkSize, text.length);\n    const chunkText = text.slice(start, end);\n    \n    // Try to break at sentence boundaries\n    let actualEnd = end;\n    if (end < text.length) {\n      const lastPeriod = chunkText.lastIndexOf('.');\n      const lastQuestion = chunkText.lastIndexOf('?');\n      const lastExclaim = chunkText.lastIndexOf('!');\n      const breakPoint = Math.max(lastPeriod, lastQuestion, lastExclaim);\n      \n      if (breakPoint > chunkSize * 0.7) { // At least 70% of chunk size\n        actualEnd = start + breakPoint + 1;\n      }\n    }\n    \n    chunks.push({\n      text: text.slice(start, actualEnd).trim(),\n      startChar: start,\n      endChar: actualEnd\n    });\n    \n    start = actualEnd + 1; // FIX: Changed from start + (chunkSize - overlap)\n    if (start >= text.length) break;\n  }\n  \n  return chunks;\n}\n\n// Create chunks\nconst chunks = chunkTextWithOverlap(transcript, 1000, 200);\n\nconsole.log(`Created ${chunks.length} chunks from transcript`);\n\nif (chunks.length === 0) {\n  throw new Error('No chunks created - transcript chunking failed');\n}\n\n// Estimate timestamps\nconst durationParts = videoMetadata.duration.split(':');\nlet totalSeconds = 0;\n\nif (durationParts.length === 3) {\n  totalSeconds = parseInt(durationParts[0]) * 3600 + \n                 parseInt(durationParts[1]) * 60 + \n                 parseInt(durationParts[2]);\n} else if (durationParts.length === 2) {\n  totalSeconds = parseInt(durationParts[0]) * 60 + \n                 parseInt(durationParts[1]);\n}\n\n// Create output with full metadata for each chunk\nreturn chunks.map((chunk, index) => {\n  const progressRatio = chunk.startChar / transcript.length;\n  const estimatedSeconds = Math.floor(totalSeconds * progressRatio);\n  \n  return {\n    json: {\n      // CRITICAL: pageContent MUST be the actual transcript text\n      pageContent: chunk.text,\n      \n      // Metadata that will be stored with the vector\n      metadata: {\n        video_id: urlData.video_id,\n        video_title: videoMetadata.video_title,\n        video_url: videoMetadata.video_url,\n        author: videoMetadata.author,\n        category: videoMetadata.category,\n        duration: videoMetadata.duration,\n        thumbnail_url: videoMetadata.thumbnail_url,\n        published_at: videoMetadata.published_at,\n        \n        // Chunk-specific metadata\n        chunk_index: index,\n        total_chunks: chunks.length,\n        estimated_timestamp_seconds: estimatedSeconds,\n        estimated_timestamp_formatted: new Date(estimatedSeconds * 1000).toISOString().substr(11, 8),\n        \n        // For citation\n        source_type: 'youtube_transcript',\n        indexed_at: new Date().toISOString()\n      }\n    }\n  };\n});"
      },
