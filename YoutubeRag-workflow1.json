    {
      "parameters": {
        "jsCode": "const content = $input.first().json.content || '';\n\n// Language detection by word frequency\nconst spanishWords = ['el', 'la', 'que', 'de', 'es', 'en', 'para', 'con', 'por', 'una', 'un', 'y'];\nconst frenchWords = ['le', 'de', 'que', 'est', 'et', 'un', 'une', 'pour', 'avec', 'la', 'les', 'est'];\nconst germanWords = ['der', 'die', 'und', 'in', 'von', 'zu', 'das', 'mit', 'sich', 'des', 'den'];\nconst portugueseWords = ['o', 'a', 'de', 'que', 'é', 'para', 'com', 'um', 'por', 'uma', 'aos'];\nconst urduWords = ['ہے', 'کو', 'میں', 'نے', 'کا', 'کی', 'اور', 'ہے', 'وہ', 'یہ'];\nconst hindiWords = ['है', 'को', 'में', 'ने', 'का', 'की', 'और', 'यह', 'वह', 'जो'];\n\nconst words = content.toLowerCase().split(/\\s+/).slice(0, 300);\n\nlet scores = { es: 0, fr: 0, de: 0, pt: 0, ur: 0, hi: 0, en: 0 };\n\nwords.forEach(word => {\n  if (spanishWords.includes(word)) scores.es++;\n  if (frenchWords.includes(word)) scores.fr++;\n  if (germanWords.includes(word)) scores.de++;\n  if (portugueseWords.includes(word)) scores.pt++;\n  if (urduWords.includes(word)) scores.ur++;\n  if (hindiWords.includes(word)) scores.hi++;\n});\n\nlet detectedLang = 'en';\nconst maxScore = Math.max(scores.es, scores.fr, scores.de, scores.pt, scores.ur, scores.hi);\n\nif (maxScore > 10) {\n  if (scores.es === maxScore) detectedLang = 'es';\n  else if (scores.fr === maxScore) detectedLang = 'fr';\n  else if (scores.de === maxScore) detectedLang = 'de';\n  else if (scores.pt === maxScore) detectedLang = 'pt';\n  else if (scores.ur === maxScore) detectedLang = 'ur';\n  else if (scores.hi === maxScore) detectedLang = 'hi';\n}\n\nconsole.log(`Detected language: ${detectedLang}, Score: ${maxScore}`);\n\nreturn [{\n  json: {\n    ...$input.first().json,\n    detected_language: detectedLang,\n    needs_translation: detectedLang !== 'en'\n  }\n}];"
      },
