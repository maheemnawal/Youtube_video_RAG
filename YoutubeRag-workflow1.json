      "parameters": {
        "jsCode": "// Get data from previous nodes\nconst videoData = $('Parse YouTube Metadata').first().json;\nconst summaryData = $('Extract Summary Text').first().json;\nconst urlData = $('extract video url').first().json;\n\n// Calculate processing time\nconst startTime = new Date(urlData.processing_start_time);\nconst endTime = new Date();\nconst processingSeconds = (endTime - startTime) / 1000;\n\n// Get chunk count from the chunking node\nconst chunkItems = $('Chunk Transcript with Metadata').all();\nconst chunksCount = chunkItems.length;\n\n// Get Pinecone data\nconst pineconeItems = $('Pinecone Vector Store').all();\n\n// Extract Pinecone IDs\nlet pineconeIds = [];\ntry {\n  pineconeIds = pineconeItems\n    .map(item => item.json?.id || item.json?.vector?.id)\n    .filter(Boolean);\n} catch (e) {\n  console.log('Could not extract Pinecone IDs:', e.message);\n}\n\n// Create stats object\nconst stats = {\n  row_id: urlData.row_id,\n  video_id: urlData.video_id,\n  chunks_count: chunksCount,\n  processing_time_seconds: processingSeconds.toFixed(2),\n  indexed_at: endTime.toISOString(),\n  summary: summaryData.summary,\n  status: 'completed',\n  pinecone_ids: pineconeIds.slice(0, 10).join(',') // First 10 IDs only\n};\n\nreturn [{ json: stats }];"
      },
